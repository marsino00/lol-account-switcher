{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoL Account Switcher",
  "mainBinaryName": "lolAccSwitcher",
  "version": "0.1.0",
  "identifier": "com.roger.lol-switcher",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LoL Account Switcher",
        "width": 900,
        "height": 800,
        "minWidth": 500,
        "minHeight": 400,
        "maxWidth": 800,
        "maxHeight": 650,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}